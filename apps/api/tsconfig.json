{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "outDir": "dist",
    "rootDir": "src",

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "types": ["node"],
    "ignoreDeprecations": "6.0",

    "baseUrl": ".",
    "paths": {
      "@framecraft/shared": ["../../packages/shared/src"]
    }
  },
  "include": ["src"]
}